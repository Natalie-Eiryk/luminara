{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://luminara.natalie-eiryk.com/schemas/scaffold.json",
  "title": "Ms. Luminara Question Scaffold",
  "description": "Schema for ZPD-based scaffolding questions",
  "type": "object",
  "required": ["parentId", "parentQuestion", "scaffolds"],
  "properties": {
    "parentId": {
      "type": "string",
      "pattern": "^\\d{3}\\.\\d+\\.\\d+$",
      "description": "Parent question ID (e.g., 611.2.01)"
    },
    "parentQuestion": {
      "type": "string",
      "minLength": 10,
      "description": "Full text of parent question"
    },
    "scaffolds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "$ref": "#/definitions/scaffoldQuestion"
      },
      "description": "Prerequisite warmup questions (1-5 recommended)"
    }
  },
  "definitions": {
    "scaffoldQuestion": {
      "type": "object",
      "required": ["q", "options", "answer", "difficulty", "explain", "wrongExplains"],
      "properties": {
        "q": {
          "type": "string",
          "minLength": 10,
          "description": "Scaffold question text"
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Answer options"
        },
        "answer": {
          "type": "integer",
          "minimum": 0,
          "description": "Index of correct answer (0-based)"
        },
        "difficulty": {
          "type": "string",
          "enum": ["foundation", "intermediate", "advanced"],
          "description": "Difficulty level - foundation builds basics, intermediate bridges to parent"
        },
        "explain": {
          "type": "string",
          "minLength": 20,
          "description": "Explanation of correct answer"
        },
        "wrongExplains": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 10
          },
          "description": "Map of option index -> explanation for wrong answers"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Topic tags"
        }
      }
    }
  }
}
